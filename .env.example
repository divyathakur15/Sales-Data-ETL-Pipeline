# ============================================
# Environment Variables - COPY THIS TO .env
# ============================================
# 
# HOW TO USE:
# 1. Copy this file and rename it to ".env" (just .env, no other name)
# 2. Replace the values with your actual MySQL credentials
# 3. NEVER commit .env to GitHub (it contains your password!)
#
# ============================================

# MySQL Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sales_dwh
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ETL Settings
ETL_BATCH_SIZE=1000
LOG_LEVEL=INFO
